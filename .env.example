# Copy this file to ".env" and fill in your values.

# Your free TMDB (The Movie Database) API key — get one at:
# https://www.themoviedb.org/settings/api
# When set, all your friends share this key automatically and never have to enter their own.
TMDB_API_KEY=

# Optional — your free Watchmode API key: https://api.watchmode.com/
# Enables "open the exact title on Netflix / Prime" deep-links in the detail view.
# Leave blank to fall back to opening each service's search for the title.
WATCHMODE_API_KEY=

# Port the server listens on (default 3001). This is the port you expose with ngrok.
PORT=3001
